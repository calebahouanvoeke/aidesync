<style>
  :root { --grad: linear-gradient(135deg,#667eea,#764ba2); --radius:14px; }

  .page-header { margin-bottom:1.75rem; }
  .page-title { font-size:1.4rem; font-weight:800; color:#1e293b; }

  .search-bar {
    background:#fff; border-radius:var(--radius); padding:1rem 1.25rem;
    box-shadow:0 2px 10px rgba(0,0,0,.06); margin-bottom:1.5rem;
    display:flex; align-items:center; gap:.75rem; flex-wrap:wrap;
  }
  .search-wrap { flex:1; min-width:200px; position:relative; }
  .search-wrap i { position:absolute; left:.85rem; top:50%; transform:translateY(-50%); color:#94a3b8; font-size:.82rem; }
  .search-wrap input {
    width:100%; padding:.55rem .9rem .55rem 2.2rem;
    border:1.5px solid #e2e8f0; border-radius:9px; font-size:.87rem; outline:none; transition:.15s;
  }
  .search-wrap input:focus { border-color:#667eea; box-shadow:0 0 0 3px rgba(102,126,234,.1); }

  .f-btn { padding:.5rem .9rem; border-radius:9px; border:1.5px solid #e2e8f0; background:none; color:#64748b; font-size:.8rem; cursor:pointer; transition:.15s; font-weight:600; }
  .f-btn.active, .f-btn:hover { border-color:#667eea; color:#667eea; background:rgba(102,126,234,.06); }
  .f-count { font-size:.78rem; color:#94a3b8; margin-left:auto; white-space:nowrap; }

  /* CARD */
  .c-card { border-radius:var(--radius); border:1.5px solid #e2e8f0; background:#fff; box-shadow:0 2px 8px rgba(0,0,0,.04); transition:.15s; height:100%; }
  .c-card:hover { box-shadow:0 6px 24px rgba(0,0,0,.09); transform:translateY(-2px); border-color:#c7d2fe; }
  .c-card.off { opacity:.62; }

  .c-top { padding:1rem 1.1rem .75rem; display:flex; gap:.75rem; align-items:flex-start; border-bottom:1px solid #f8fafc; }
  .c-av {
    width:44px; height:44px; border-radius:12px; flex-shrink:0;
    background:var(--grad); display:flex; align-items:center; justify-content:center;
    color:#fff; font-weight:800; font-size:.92rem; letter-spacing:.03em;
  }
  .c-av.off { background:#e2e8f0; color:#94a3b8; }
  .c-nom { font-weight:700; font-size:.93rem; color:#1e293b; }
  .c-ville { font-size:.73rem; color:#94a3b8; margin-top:.1rem; display:flex; align-items:center; gap:.3rem; }
  .b-on  { background:#dcfce7; color:#16a34a; padding:.18rem .55rem; border-radius:20px; font-size:.68rem; font-weight:700; }
  .b-off { background:#f1f5f9; color:#94a3b8;  padding:.18rem .55rem; border-radius:20px; font-size:.68rem; font-weight:700; }

  .c-info { padding:.75rem 1.1rem 0; }
  .c-row { display:flex; align-items:center; gap:.45rem; font-size:.8rem; color:#475569; margin-bottom:.3rem; }
  .c-row i { width:13px; color:#94a3b8; font-size:.72rem; }
  .c-row a { color:#475569; text-decoration:none; } .c-row a:hover { color:#667eea; }

  .c-stats { display:flex; margin:.7rem 0; background:#f8fafc; border-radius:10px; overflow:hidden; }
  .c-stat { flex:1; padding:.5rem .4rem; text-align:center; }
  .c-stat+.c-stat { border-left:1px solid #e2e8f0; }
  .c-stat-n { font-weight:800; font-size:.95rem; color:#1e293b; }
  .c-stat-l { font-size:.62rem; color:#94a3b8; text-transform:uppercase; letter-spacing:.04em; }

  .c-foot { padding:.7rem 1.1rem; border-top:1px solid #f8fafc; display:flex; gap:.4rem; }
  .c-act {
    flex:1; padding:.42rem .3rem; border-radius:8px; border:1.5px solid #e2e8f0;
    background:none; font-size:.76rem; color:#475569; cursor:pointer; text-decoration:none;
    text-align:center; transition:.15s; font-weight:600; display:flex; align-items:center; justify-content:center; gap:.25rem;
  }
  .c-act:hover { border-color:#667eea; color:#667eea; background:rgba(102,126,234,.04); }
  .c-act.prim { background:var(--grad); border-color:transparent; color:#fff; }
  .c-act.prim:hover { opacity:.85; color:#fff; }

  .empty-state { text-align:center; padding:4rem 2rem; color:#cbd5e1; }
  .empty-state i { font-size:3rem; margin-bottom:1rem; display:block; }
</style>

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
  <div>
    <div class="page-title"><i class="fas fa-users me-2 text-primary"></i>Mes clients</div>
    <small class="text-muted" id="sub"></small>
  </div>
  <a href="/clients/create" class="btn btn-primary" style="border-radius:10px;background:var(--grad);border:none;font-weight:600;padding:.6rem 1.2rem;">
    <i class="fas fa-user-plus me-2"></i>Nouveau client
  </a>
</div>

<div class="search-bar">
  <div class="search-wrap">
    <i class="fas fa-search"></i>
    <input type="text" id="q" placeholder="Nom, ville, téléphone…" oninput="render()">
  </div>
  <button class="f-btn active" id="btnAll"     onclick="setF('all')">Tous <span id="nAll"></span></button>
  <button class="f-btn"        id="btnActif"   onclick="setF('actif')">Actifs <span id="nActif"></span></button>
  <button class="f-btn"        id="btnInactif" onclick="setF('inactif')">Inactifs <span id="nInactif"></span></button>
  <div class="f-count" id="shown"></div>
</div>

<div class="row" id="grid">
<% if (clients && clients.length > 0) { %>
  <% clients.forEach(client => {
       const initiales = client.prenom.charAt(0).toUpperCase() + client.nom.charAt(0).toUpperCase();
       const actif = client.statut_actif;
       let derniereStr = '—';
       if (client.derniere_intervention) {
         const d = new Date(client.derniere_intervention);
         derniereStr = new Date(d.getFullYear(), d.getMonth(), d.getDate())
           .toLocaleDateString('fr-FR',{day:'numeric',month:'short'});
       }
  %>
  <div class="col-md-6 col-xl-4 mb-3 c-wrap"
       data-name="<%= (client.prenom+' '+client.nom).toLowerCase() %>"
       data-ville="<%= (client.ville||'').toLowerCase() %>"
       data-tel="<%= (client.telephone||'') %>"
       data-statut="<%= actif ? 'actif' : 'inactif' %>">
    <div class="c-card <%= actif?'':'off' %>">
      <div class="c-top">
        <div class="c-av <%= actif?'':'off' %>"><%= initiales %></div>
        <div style="flex:1;min-width:0">
          <div class="c-nom"><%= client.prenom %> <%= client.nom %></div>
          <div class="c-ville"><i class="fas fa-map-marker-alt"></i><%= client.ville %></div>
        </div>
        <% if (actif) { %><span class="b-on">Actif</span><% } else { %><span class="b-off">Inactif</span><% } %>
      </div>

      <div class="c-info">
        <div class="c-row"><i class="fas fa-phone"></i><a href="tel:<%= client.telephone %>"><%= client.telephone %></a></div>
        <% if (client.email) { %>
        <div class="c-row"><i class="fas fa-envelope"></i><a href="mailto:<%= client.email %>" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:220px;display:block;"><%= client.email %></a></div>
        <% } %>
        <div class="c-stats">
          <div class="c-stat"><div class="c-stat-n"><%= client.nombre_interventions||0 %></div><div class="c-stat-l">Interv.</div></div>
          <div class="c-stat"><div class="c-stat-n"><%= parseFloat(client.heures_totales||0).toFixed(1) %>h</div><div class="c-stat-l">Heures</div></div>
          <div class="c-stat"><div class="c-stat-n" style="font-size:.78rem;"><%= derniereStr %></div><div class="c-stat-l">Dernière</div></div>
        </div>
      </div>

      <div class="c-foot">
        <a href="/clients/<%= client.id %>" class="c-act prim"><i class="fas fa-eye"></i> Fiche</a>
        <a href="/clients/<%= client.id %>/edit" class="c-act"><i class="fas fa-edit"></i> Modifier</a>
        <a href="/interventions/create?client_id=<%= client.id %>" class="c-act" title="Nouvelle intervention"><i class="fas fa-plus"></i></a>
      </div>
    </div>
  </div>
  <% }) %>
<% } else { %>
  <div class="col-12">
    <div class="empty-state">
      <i class="fas fa-users"></i>
      <h5 style="color:#475569">Aucun client pour le moment</h5>
      <a href="/clients/create" class="btn btn-primary mt-2" style="border-radius:10px;background:var(--grad);border:none;">
        <i class="fas fa-user-plus me-2"></i>Ajouter un client
      </a>
    </div>
  </div>
<% } %>
</div>

<div class="text-center text-muted py-4" id="noRes" style="display:none">
  <i class="fas fa-search me-2"></i>Aucun résultat
</div>

<script>
let curF = 'all';
const all = document.querySelectorAll('.c-wrap');
const nAll = [...all].length;
const nActif   = [...all].filter(c=>c.dataset.statut==='actif').length;
const nInactif = [...all].filter(c=>c.dataset.statut==='inactif').length;
document.getElementById('nAll').textContent    = `(${nAll})`;
document.getElementById('nActif').textContent  = `(${nActif})`;
document.getElementById('nInactif').textContent= `(${nInactif})`;
document.getElementById('sub').textContent     = `${nActif} client${nActif>1?'s':''} actif${nActif>1?'s':''}`;

function setF(f) {
  curF = f;
  ['All','Actif','Inactif'].forEach(x=>document.getElementById('btn'+x).classList.remove('active'));
  document.getElementById('btn'+f.charAt(0).toUpperCase()+f.slice(1)).classList.add('active');
  render();
}

function render() {
  const q = document.getElementById('q').value.toLowerCase();
  let v = 0;
  all.forEach(c => {
    const okS = curF==='all'||c.dataset.statut===curF;
    const okQ = !q||c.dataset.name.includes(q)||c.dataset.ville.includes(q)||c.dataset.tel.includes(q);
    c.style.display = okS&&okQ ? '' : 'none';
    if(okS&&okQ) v++;
  });
  document.getElementById('shown').textContent = `${v} affiché${v>1?'s':''}`;
  document.getElementById('noRes').style.display = v===0 ? '' : 'none';
}
render();
</script>

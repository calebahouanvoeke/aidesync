<script>
  // Calculé dans le navigateur = toujours heure locale correcte
  const today = new Date();
  const day = today.getDay(); // 0=Dim, 1=Lun...
  const diff = (day === 0) ? -6 : 1 - day; // ramène au lundi

  const start = new Date(today.getFullYear(), today.getMonth(), today.getDate() + diff);
  const end   = new Date(today.getFullYear(), today.getMonth(), today.getDate() + diff + 6);

  const fmt = d => `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;

  window.location.replace(`/interventions?start=${fmt(start)}&end=${fmt(end)}`);
</script>

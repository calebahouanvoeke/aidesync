<h2 class="text-center mb-4">Créer un compte</h2>

<% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
  <div class="alert d-flex align-items-start gap-2 mb-3"
       style="border-radius:12px;border:none;background:#fef2f2;color:#dc2626;font-size:0.88rem;padding:0.85rem 1.1rem;">
    <i class="fas fa-exclamation-circle mt-1" style="flex-shrink:0;"></i>
    <div>
      <strong>Impossible de créer le compte</strong><br>
      <span><%= errors[0] %></span>
    </div>
  </div>
<% } %>

<form action="/auth/register" method="POST" id="registerForm" novalidate>
  <div class="row">
    <div class="col-md-6 mb-3">
      <label for="nom" class="form-label">Nom <span class="text-danger">*</span></label>
      <input type="text" class="form-control" id="nom" name="nom" value="<%= formData.nom || '' %>" required>
      <div class="invalid-feedback">Le nom est obligatoire.</div>
    </div>
    <div class="col-md-6 mb-3">
      <label for="prenom" class="form-label">Prénom <span class="text-danger">*</span></label>
      <input type="text" class="form-control" id="prenom" name="prenom" value="<%= formData.prenom || '' %>" required>
      <div class="invalid-feedback">Le prénom est obligatoire.</div>
    </div>
  </div>

  <div class="mb-3">
    <label for="email" class="form-label">Email <span class="text-danger">*</span></label>
    <input type="email" class="form-control" id="email" name="email" value="<%= formData.email || '' %>" required placeholder="votre@email.com">
    <div class="invalid-feedback" id="emailRegFeedback">Veuillez saisir un email valide.</div>
  </div>

  <div class="mb-3">
    <label for="telephone" class="form-label">Téléphone <span class="text-danger">*</span></label>
    <input type="tel" class="form-control" id="telephone" name="telephone" value="<%= formData.telephone || '' %>" required>
    <div class="invalid-feedback">Le téléphone est obligatoire.</div>
  </div>

  <div class="mb-3">
    <label for="siret" class="form-label">SIRET</label>
    <input type="text" class="form-control" id="siret" name="siret" value="<%= formData.siret || '' %>" maxlength="14" placeholder="14 chiffres">
  </div>

  <div class="mb-3">
    <label for="adresse" class="form-label">Adresse</label>
    <input type="text" class="form-control" id="adresse" name="adresse" value="<%= formData.adresse || '' %>">
  </div>

  <div class="row">
    <div class="col-md-8 mb-3">
      <label for="ville" class="form-label">Ville</label>
      <input type="text" class="form-control" id="ville" name="ville" value="<%= formData.ville || '' %>">
    </div>
    <div class="col-md-4 mb-3">
      <label for="code_postal" class="form-label">Code postal</label>
      <input type="text" class="form-control" id="code_postal" name="code_postal" value="<%= formData.code_postal || '' %>" maxlength="5">
    </div>
  </div>

  <div class="mb-3">
    <label for="mot_de_passe" class="form-label">Mot de passe <span class="text-danger">*</span></label>
    <div class="input-group">
      <input type="password" class="form-control" id="mot_de_passe" name="mot_de_passe" minlength="8" required placeholder="8 caractères minimum" oninput="checkRegStrength(this.value)">
      <button type="button" class="input-group-text" style="cursor:pointer;" onclick="toggleRegPwd('mot_de_passe','eyeReg1')"><i class="fas fa-eye" id="eyeReg1"></i></button>
    </div>
    <div style="height:4px;border-radius:2px;background:#e2e8f0;margin-top:0.4rem;overflow:hidden;"><div id="regStrengthBar" style="height:100%;width:0%;border-radius:2px;transition:all 0.3s;"></div></div>
    <small id="regStrengthText" style="font-size:0.72rem;color:#94a3b8;"></small>
    <div class="invalid-feedback">Le mot de passe doit contenir au moins 8 caractères.</div>
  </div>

  <div class="mb-3">
    <label for="confirm_password" class="form-label">Confirmer le mot de passe <span class="text-danger">*</span></label>
    <div class="input-group">
      <input type="password" class="form-control" id="confirm_password" name="confirm_password" required>
      <button type="button" class="input-group-text" style="cursor:pointer;" onclick="toggleRegPwd('confirm_password','eyeReg2')"><i class="fas fa-eye" id="eyeReg2"></i></button>
    </div>
    <div class="invalid-feedback" id="confirmFeedback">Les mots de passe ne correspondent pas.</div>
  </div>

  <button type="submit" class="btn btn-primary w-100 mb-3" id="registerBtn">
    <i class="fas fa-user-plus me-2"></i>Créer mon compte
  </button>

  <div class="text-center">
    <p class="mb-0">Déjà un compte ? <a href="/auth/login" class="text-decoration-none">Se connecter</a></p>
  </div>
</form>

<script>
function toggleRegPwd(inputId, iconId) {
  const input = document.getElementById(inputId);
  const icon  = document.getElementById(iconId);
  input.type  = input.type === 'password' ? 'text' : 'password';
  icon.className = input.type === 'password' ? 'fas fa-eye' : 'fas fa-eye-slash';
}
function checkRegStrength(val) {
  let score = 0;
  if (val.length >= 8) score++;
  if (/[A-Z]/.test(val)) score++;
  if (/[0-9]/.test(val)) score++;
  if (/[^A-Za-z0-9]/.test(val)) score++;
  const levels = [{w:'25%',c:'#ef4444',t:'Très faible'},{w:'50%',c:'#f97316',t:'Faible'},{w:'75%',c:'#eab308',t:'Moyen'},{w:'100%',c:'#22c55e',t:'Fort'}];
  const lvl = levels[Math.max(score-1,0)];
  const bar  = document.getElementById('regStrengthBar');
  const text = document.getElementById('regStrengthText');
  bar.style.width = val ? lvl.w : '0%'; bar.style.background = lvl.c;
  text.textContent = val ? lvl.t : ''; text.style.color = lvl.c;
}
document.getElementById('registerForm').addEventListener('submit', function(e) {
  let valid = true;
  const fields = ['nom','prenom','telephone'];
  fields.forEach(f => {
    const el = document.getElementById(f);
    if (!el.value.trim()) { el.classList.add('is-invalid'); valid = false; }
    else el.classList.remove('is-invalid');
  });
  const email = document.getElementById('email');
  if (!email.value || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) {
    email.classList.add('is-invalid'); document.getElementById('emailRegFeedback').textContent='Veuillez saisir un email valide.'; valid=false;
  } else email.classList.remove('is-invalid');
  const pwd  = document.getElementById('mot_de_passe');
  const conf = document.getElementById('confirm_password');
  if (!pwd.value || pwd.value.length < 8) { pwd.classList.add('is-invalid'); valid=false; }
  else pwd.classList.remove('is-invalid');
  if (conf.value !== pwd.value) {
    conf.classList.add('is-invalid'); document.getElementById('confirmFeedback').textContent='Les mots de passe ne correspondent pas.'; valid=false;
  } else conf.classList.remove('is-invalid');
  if (!valid) e.preventDefault();
  else { const btn=document.getElementById('registerBtn'); btn.disabled=true; btn.innerHTML='<i class="fas fa-spinner fa-spin me-2"></i>Création...'; }
});
</script>
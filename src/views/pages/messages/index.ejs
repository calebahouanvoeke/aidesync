<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">
    <i class="fas fa-envelope me-2"></i>
    Messagerie
  </h1>
</div>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <% if (conversations.length > 0) { %>
          <div class="list-group list-group-flush">
            <% conversations.forEach(conv => { %>
              <a href="/messages/<%= conv.client.id %>" 
                 class="list-group-item list-group-item-action">
                <div class="d-flex w-100 justify-content-between align-items-start">
                  <div class="d-flex align-items-center">
                    <div class="me-3">
                      <i class="fas fa-user-circle fa-3x text-secondary"></i>
                    </div>
                    <div>
                      <h5 class="mb-1">
                        <%= conv.client.prenom %> <%= conv.client.nom %>
                        <% if (conv.unreadCount > 0) { %>
                          <span class="badge bg-danger ms-2"><%= conv.unreadCount %></span>
                        <% } %>
                      </h5>
                      <p class="mb-1 text-muted small">
                        <%= conv.lastMessage.contenu.substring(0, 100) %>
                        <%= conv.lastMessage.contenu.length > 100 ? '...' : '' %>
                      </p>
                      <small class="text-muted">
                        <i class="far fa-clock me-1"></i>
                        <%= new Date(conv.lastMessage.date_envoi).toLocaleDateString('fr-FR', { 
                          day: 'numeric', 
                          month: 'short', 
                          hour: '2-digit', 
                          minute: '2-digit' 
                        }) %>
                      </small>
                    </div>
                  </div>
                  <div>
                    <i class="fas fa-chevron-right text-muted"></i>
                  </div>
                </div>
              </a>
            <% }) %>
          </div>
        <% } else { %>
          <div class="text-center py-5">
            <i class="fas fa-inbox fa-4x text-muted mb-3"></i>
            <h5>Aucun message</h5>
            <p class="text-muted">Les conversations avec vos clients apparaîtront ici</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>